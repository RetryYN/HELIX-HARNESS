{
  "description": "Codex CLI project-local hook adapter (PLAN-L7-139)。Codex は <repo>/.codex/hooks.json を読み、schema 上 top-level は description|hooks のみ許容 ($comment は 0.144 で parse error になり hooks 全体が無効化される)。.claude/settings.json の guard hooks を Codex tool 名で mirror し、同じ TypeScript entrypoint を再利用する。global ~/.codex/ へ移動しない。",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "spawn_agent|spawn_agents_on_csv|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/agent-guard.ts",
            "timeout": 5,
            "statusMessage": "agent-guard: Codex sub-agent role/model guard (PLAN-L7-139)",
            "blockOnFailure": true
          }
        ]
      },
      {
        "matcher": "apply_patch|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/work-guard.ts",
            "timeout": 5,
            "statusMessage": "work guard: block edits to foreign uncommitted files unless explicitly bypassed (Codex parity, PLAN-L7-139)",
            "blockOnFailure": true
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun .claude/hooks/git-command-guard.ts",
            "timeout": 5,
            "statusMessage": "git-command-guard: block destructive git operations unless explicitly bypassed (Codex parity)",
            "blockOnFailure": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts session start",
            "timeout": 90,
            "statusMessage": "session-log: session start (fail-open)"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "apply_patch|Write|Edit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts hook post-tool-use",
            "timeout": 30,
            "statusMessage": "session-log: post tool use (fail-open)"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts hook subagent-stop --quiet",
            "timeout": 30,
            "statusMessage": "agent-slots: release subagent slot (fail-open; --quiet = Codex 0.144 は非 JSON stdout を Failed 扱い)"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/cli.ts session summary --quiet",
            "timeout": 60,
            "statusMessage": "session-log: PLAN digest summary (fail-open; --quiet = Codex 0.144 は Stop hook の非 JSON stdout を Failed 扱い)"
          }
        ]
      }
    ]
  }
}
