{
  "name": "helix",
  "version": "0.1.0",
  "description": "HELIX-HARNESS — AI 実装エージェントを安全に使う検証・開発基盤 (TypeScript core, ADR-001)",
  "license": "MIT",
  "type": "module",
  "private": true,
  "bin": {
    "helix": "./dist/helix.js"
  },
  "engines": {
    "node": ">=24.15.0 <25"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "helix": "tsx src/cli.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=esm --target=node24 --packages=external --outfile=dist/helix.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests",
    "format": "biome check --write src tests",
    "test": "sh -c 'if [ \"${CI:-}\" = \"true\" ]; then vitest run --project fast --project slow; else vitest run --project fast; fi'",
    "test:fast": "vitest run --project fast",
    "test:slow": "vitest run --project slow",
    "test:local": "vitest run --project fast --exclude tests/distribution-acceptance.test.ts",
    "test:node-fallback": "vitest run tests/state-db.test.ts tests/runtime-portability.test.ts",
    "test:watch": "vitest"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "dependencies": {
    "commander": "^12.1.0",
    "typescript": "^5.6.3",
    "yaml": "^2.5.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^22.7.4",
    "@vitest/coverage-v8": "2.1.9",
    "esbuild": "^0.25.0",
    "tsx": "^4.23.1",
    "vitest": "^2.1.2"
  }
}
