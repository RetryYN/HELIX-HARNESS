    expected_terminal_receipt_count: 0
  - mutation_id: stage_axis_mixed
    expected_failure: HIL_LAYER_PROGRESS_STAGE_ORDER_INVALID
    expected_terminal_receipt_count: 0
  - mutation_id: evidence_stale_or_source_swapped
    expected_failure: HIL_LAYER_PROGRESS_EVIDENCE_STALE
    expected_terminal_receipt_count: 0
  - mutation_id: reviewer_identity_not_separated
    expected_failure: HIL_LAYER_PROGRESS_AUDITOR_NOT_INDEPENDENT
    expected_terminal_receipt_count: 0
  - mutation_id: evidence_receipt_missing_or_swapped
    expected_failure: HIL_LAYER_PROGRESS_RECEIPT_MISMATCH
    expected_terminal_receipt_count: 0
  - mutation_id: freeze_slice_or_snapshot_join_mismatch
    expected_failure: HIL_LAYER_PROGRESS_RECEIPT_MISMATCH
    expected_terminal_receipt_count: 0
  - mutation_id: projection_rate_or_digest_mismatch
    expected_failure: HIL_LAYER_PROGRESS_PROJECTION_MISMATCH
    expected_terminal_receipt_count: 0
  - mutation_id: supporting_oracle_included
    expected_failure: HIL_LAYER_PROGRESS_SUPPORTING_INCLUDED
    expected_terminal_receipt_count: 0
  - mutation_id: store_revision_head_cas_loser
    expected_failure: HIL_LAYER_TRANSACTION_CAS_CONFLICT
    expected_terminal_receipt_count: 0
  - mutation_id: append_fault_same_digest_reconcile
    expected_failure: none
    expected_terminal_receipt_count: 1
    expected_terminal_receipt_id: DPR-LLPG-S01-V1
