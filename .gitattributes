# HELIX line-ending normalization (止: CRLF/LF churn)
* text=auto eol=lf

# Windows PowerShell entrypoints keep CRLF
*.ps1 text eol=crlf
*.cmd text eol=crlf
*.bat text eol=crlf

# Binaries / lockfiles
bun.lockb binary
*.png binary
*.jpg binary
*.ico binary

# Repo-owned predecessor source custody; content-addressed bundles are never text-normalized.
source-cas/git-authority/sha256/**/*.bundle binary -diff
