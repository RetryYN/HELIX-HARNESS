.tools/
# 外部 DL の設計テンプレ研究素材 (transient scratch、アーキ境界外・成果物でない)
downloads/

# HELIX runtime state
.helix/

# Atomic handover retirement authority is product evidence, not rebuildable runtime state.
!.helix/
.helix/*
!.helix/audit/
.helix/audit/*
!.helix/audit/session-handover-retirement.jsonl
!.helix/approvals/
.helix/approvals/*
!.helix/approvals/session-handover-cutover.json

# Python bytecode (旧 W1-W3a port の残骸。ADR-001 で TS rebuild、念のため残置)
__pycache__/
*.py[cod]
*$py.class

# PLAN frontmatter runtime lock (W1 cross-platform lock impl)
docs/plans/*.lock

# Node / TypeScript (HELIX-HARNESS core, ADR-001)
node_modules/
dist/
*.tsbuildinfo
coverage/
.vitest/

# OS / editor junk (Windows / macOS / Linux クロスプラットフォーム team)
.DS_Store
Thumbs.db
ehthumbs.db
*.swp
*~

# debug logs
*-debug.log
npm-debug.log*
bun-debug.log*
# 注: .vscode/ は共有設定 (settings.json / extensions.json) を commit したい場合があるため意図的に未 ignore (team 判断)
